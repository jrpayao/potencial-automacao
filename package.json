{
  "name": "@ipa/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start:frontend": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx serve frontend",
    "start:api": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx serve api",
    "build:frontend": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx build frontend",
    "build:api": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx build api",
    "build:shared": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx build shared",
    "build:all": "NX_IGNORE_UNSUPPORTED_TS_SETUP=true nx run-many -t build",
    "seed": "npx tsx --tsconfig apps/api/tsconfig.seed.json apps/api/src/database/seed.ts",
    "deploy:frontend": "CAPROVER_MACHINE=captain-01 CAPROVER_FRONTEND_APP=ipa bash scripts/caprover-deploy.sh frontend",
    "deploy:api": "CAPROVER_MACHINE=captain-01 bash scripts/caprover-deploy.sh api",
    "deploy:all": "CAPROVER_MACHINE=captain-01 CAPROVER_FRONTEND_APP=ipa bash scripts/caprover-deploy.sh all"
  },
  "private": true,
