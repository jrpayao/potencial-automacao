{
  "compilerOptions": {
    "target": "es2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": "../..",
    "paths": {
      "@ipa/shared": ["libs/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../../libs/shared/src/**/*.ts"]
}
